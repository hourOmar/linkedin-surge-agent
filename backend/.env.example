# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic Claude API key (required)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Claude model to use for generation and evaluation calls
MODEL_NAME=claude-sonnet-5

# Sampling temperature for generation calls
TEMPERATURE=0.7

# Max auto-revision loop iterations before handing off to human review
MAX_REVISIONS=2

# Minimum average rubric score (0-10) a draft must hit before skipping revision
EVAL_THRESHOLD=7.0

# SQLite database file path
DB_PATH=./data/app.db

# JSON-lines log file path
LOG_PATH=./logs/agent.log
